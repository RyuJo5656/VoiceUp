# VoiceUp 환경설정
#
# 이 키들은 "선택 사항"입니다. 비워두면 무료 시스템 음성인식/합성(Google)으로 동작합니다.
# 목소리가 작거나 숨소리가 많은 경우 인식률을 높이려면 네이버 Clova 키를 넣으세요.
# https://www.ncloud.com/product/aiService/csr  (음성인식 CSR)
# https://www.ncloud.com/product/aiService/tts  (음성합성 Premium)

CLOVA_CSR_CLIENT_ID=
CLOVA_CSR_CLIENT_SECRET=

CLOVA_TTS_CLIENT_ID=
CLOVA_TTS_CLIENT_SECRET=

# 화자: nara(여), jinho(남), nminsang(남) 등
CLOVA_TTS_SPEAKER=jinho
CLOVA_TTS_SPEED=0
CLOVA_TTS_PITCH=0
CLOVA_TTS_VOLUME=5
